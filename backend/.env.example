# ── Database ────────────────────────────────────────────────
# PostgreSQL connection string
# Local:    postgresql://postgres:yourpassword@localhost:5432/stockmetry
# Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
# Neon:     postgresql://[USER]:[PASSWORD]@[HOST]/[DBNAME]?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/stockmetry

# ── Security ────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=
REFRESH_TOKEN_EXPIRE_DAYS=

# ── Demo Account Passwords (set before seeding) ─────────────
ADMIN_PASSWORD=
MANAGER_PASSWORD=
ANALYST_PASSWORD=

# ── AI Integration (Optional) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── CORS ────────────────────────────────────────────────────
# Frontend URL(s) — comma separated
ALLOWED_ORIGINS=http://localhost:5173,https://stockmetry.vercel.app

# ── File Upload ─────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50

# ── Environment ─────────────────────────────────────────────
ENVIRONMENT=development
